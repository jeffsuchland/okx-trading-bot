# =============================================================================
# OKX Trading Bot — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- OKX API Credentials (REQUIRED) ---
# Obtain from: https://www.okx.com/account/my-api
OKX_API_KEY=your_api_key_here
OKX_SECRET_KEY=your_secret_key_here
OKX_PASSPHRASE=your_passphrase_here

# Use OKX sandbox/demo environment (default: true)
OKX_SANDBOX=true

# --- Trading Settings ---
# Trading pair to trade (default: BTC-USDT)
TRADING_PAIR=BTC-USDT

# Active strategy name (default: MeanReversionStrategy)
# Options: MeanReversionStrategy, GridTradingStrategy
STRATEGY_NAME=MeanReversionStrategy

# Amount in USDT to spend per trade (default: 10)
SPEND_PER_TRADE=10

# Maximum total exposure in USDT across all positions (default: 100)
MAX_EXPOSURE=100

# --- Risk Parameters ---
# Stop-loss percentage per position (default: 2.0)
STOP_LOSS_PCT=2.0

# Stop-loss mode: "fixed" or "trailing" (default: fixed)
STOP_LOSS_MODE=fixed

# Maximum account drawdown percentage before circuit breaker triggers (default: 5.0)
MAX_DRAWDOWN_PCT=5.0

# Maximum daily loss in USDT before trading halts (default: 50.0)
DAILY_LOSS_LIMIT=50.0

# --- Server Settings ---
# Host and port for the FastAPI dashboard server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# --- Trading Loop ---
# Interval in seconds between trading loop ticks (default: 5.0)
TICK_INTERVAL=5.0
